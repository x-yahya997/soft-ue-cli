{
	"FileVersion": 3,
	"Version": 3,
	"VersionName": "1.3.2",
	"FriendlyName": "SoftUE Bridge",
	"Description": "HTTP bridge server for soft-ue-cli. Exposes UE operations (spawn actor, query level, call function, etc.) over HTTP/JSON-RPC. Active in editor, PIE, and development builds by default.",
	"Category": "Scripting",
	"CreatedBy": "soft-ue-expert",
	"CreatedByURL": "https://github.com/softdaddy-o/soft-ue-expert",
	"DocsURL": "",
	"SupportURL": "",
	"CanContainContent": false,
	"IsBetaVersion": false,
	"IsExperimentalVersion": false,
	"Installed": false,
	"EnabledByDefault": false,
	"Plugins": [
		{
			"Name": "EditorScriptingUtilities",
			"Enabled": true
		},
		{
			"Name": "StateTree",
			"Enabled": true
		},
		{
			"Name": "PythonScriptPlugin",
			"Enabled": true,
			"Optional": true
		}
	],
	"Modules": [
		{
			"Name": "SoftUEBridge",
			"Type": "DeveloperTool",
			"LoadingPhase": "Default"
		},
		{
			"Name": "SoftUEBridgeEditor",
			"Type": "Editor",
			"LoadingPhase": "PostEngineInit"
		}
	]
}
